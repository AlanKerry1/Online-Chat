// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @default(autoincrement()) @id
  name  String @unique
  directChats UsersDirectChats[]
  channelChats UsersChannelChats[]
  messages Message[]
}

model ChannelChat {
  id    Int     @default(autoincrement()) @id

  channelName String @unique

  users UsersChannelChats[]
  messages Message[]
}

model DirectChat {
  id    Int     @default(autoincrement()) @id

  users UsersDirectChats[]
  messages Message[]
}

model UsersDirectChats {
  id    Int     @default(autoincrement()) @id

  user User @relation(fields: [userId], references: [id])
  userId Int

  chat DirectChat @relation(fields: [chatId], references: [id])
  chatId Int
}

model UsersChannelChats {
  id    Int     @default(autoincrement()) @id

  user User @relation(fields: [userId], references: [id])
  userId Int

  chat ChannelChat @relation(fields: [chatId], references: [id])
  chatId Int
}

model Message {
  id    Int     @default(autoincrement()) @id

  text String

  user User @relation(fields: [userId], references: [id])
  userId Int

  channelChat ChannelChat? @relation(fields: [channelChatId], references: [id])
  channelChatId Int?

  directChat DirectChat? @relation(fields: [directChatId], references: [id])
  directChatId Int?
}